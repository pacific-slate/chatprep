/**
 * ChatPrep — Cloudflare Workers (Static Assets) config
 *
 * Pure static site, no Worker script, no build step.
 * `wrangler deploy` uploads ./public/ as static assets.
 *
 * Docs: https://developers.cloudflare.com/workers/static-assets/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chatprep",
  "compatibility_date": "2026-04-27",
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
